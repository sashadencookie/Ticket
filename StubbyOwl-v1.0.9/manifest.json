{
  "manifest_version": 3,
  "name": "Stubby Owl",
  "version": "1.0.9",
  "description": "Speed up your ticket hunting experience",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "js": [
        "src/content/anti-detect.js",
        "src/content/celtic.js"
      ],
      "css": [
        "src/content/overlay.css"
      ],
      "matches": [
        "*://www.eticketing.co.uk/celtic/*"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "js": [
        "src/content/bridge.js"
      ],
      "matches": [
        "*://www.eticketing.co.uk/celtic/*"
      ],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "proxy",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "*://www.eticketing.co.uk/celtic/*",
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/notification.mp3",
        "assets/basketed-ticket.mp3",
        "assets/not-available.mp3"
      ],
      "matches": [
        "*://www.eticketing.co.uk/*"
      ]
    }
  ]
}